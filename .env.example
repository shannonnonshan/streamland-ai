# Hugging Face Configuration
# Get your token from: https://huggingface.co/settings/tokens (write permission)
HF_TOKEN=hf_your_hugging_face_token_here
HF_USERNAME=your_hf_username
# Repos are created as:  HF_USERNAME/HF_REPO_BASE-<model_name>
# e.g. shannonnonshan/streamland-whisper
HF_REPO_BASE=streamland

# Model Configuration
MODEL_PATH=models/whisper/model/whisper-finetuned
MODEL_USE_HF=false

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# Audio Processing
AUDIO_SAMPLE_RATE=16000
AUDIO_CHUNK_LENGTH=30

# Device Configuration
DEVICE=cuda:0
TORCH_DTYPE=float16
